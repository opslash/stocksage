# ==============================================================================
# StockSage — Environment Configuration
# ==============================================================================

# ------------------------------------------------------------------------------
# GNews API Key (Required for Bloomberg/Reuters/CNBC/WSJ news feed)
# ------------------------------------------------------------------------------
# 1. Go to https://gnews.io and click "Get API Key"
# 2. Sign up for a free account (no credit card required)
# 3. Free tier: 100 requests/day — plenty for hourly background refresh
# 4. Copy your API key and paste it below (replace the placeholder)
# 5. Rename this file from ".env.example" to ".env"
#
GNEWS_API_KEY=your_gnews_api_key_here

# --- AI Integration (OpenRouter) ---
OPENROUTER_API_KEY="your_openrouter_api_key_here"

# Macro data is fetched from FRED's public CSV endpoint and does not require a key.

# ------------------------------------------------------------------------------
# App Configuration (Optional — defaults are fine for local use)
# ------------------------------------------------------------------------------
# Port the server listens on (default: 8000)
PORT=8000

# Cache TTL in minutes (default: 75 — slightly over 1 hour)
CACHE_TTL_MINUTES=75

# Enable verbose logging (true/false)
DEBUG=false
